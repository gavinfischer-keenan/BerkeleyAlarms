# =============================================================================
# BerkeleyAlarms — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.

# ── MQTT ─────────────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# ── API Server ───────────────────────────────────────────────────────
ALARM_API_HOST=0.0.0.0
ALARM_API_PORT=8084

# ── Alarm Config ─────────────────────────────────────────────────────
ALARMS_CONFIG_PATH=./alarms.yml

# ── Storage ──────────────────────────────────────────────────────────
ALARM_DB_PATH=/var/lib/berkeley/alarms.db

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
